<div class="mb-4">
  <%= link_to "← 戻る", drink_records_path, class: "text-indigo-600 hover:text-indigo-800" %>
</div>

<div class="bg-white rounded-lg shadow-lg overflow-hidden">
  <% if @drink_record.image.attached? %>
    <%= image_tag @drink_record.image, class: "w-full h-64 object-cover" %>
  <% else %>
    <div class="w-full h-40 bg-gray-200 flex items-center justify-center">
      <span class="text-gray-400">No Image</span>
    </div>
  <% end %>

  <div class="p-5">
    <h1 class="text-2xl font-bold text-gray-900 mb-1"><%= @drink_record.title %></h1>
    <p class="text-xs text-gray-400 mb-4"><%= @drink_record.created_at.strftime("%Y/%m/%d %H:%M") %></p>

    <% if @drink_record.comment.present? %>
      <div class="bg-gray-50 p-4 rounded-lg mb-6 text-gray-700 whitespace-pre-wrap"><%= @drink_record.comment %></div>
    <% end %>

    <h2 class="text-lg font-semibold text-gray-800 mb-3 border-b pb-1">評価チャート</h2>

    <div class="w-full aspect-square relative mb-6" data-controller="chart show"
         data-chart-ai-data='<%= [@drink_record.ai_sweetness, @drink_record.ai_acidity, @drink_record.ai_body, @drink_record.ai_aroma, @drink_record.ai_bitterness].to_json %>'
         data-chart-user-data='<%= [@drink_record.user_sweetness, @drink_record.user_acidity, @drink_record.user_body, @drink_record.user_aroma, @drink_record.user_bitterness].to_json %>'>
      <canvas data-chart-target="canvas"></canvas>
    </div>

    <div class="flex space-x-3 mt-6 pt-4 border-t border-gray-100">
      <%= link_to "編集", edit_drink_record_path(@drink_record), class: "flex-1 text-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
      <%= button_to "削除", @drink_record, method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "flex-1 w-full py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700" %>
    </div>
  </div>
</div>
