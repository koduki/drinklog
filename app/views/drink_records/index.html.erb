<div class="space-y-4">
  <h1 class="text-2xl font-bold text-gray-800">記録一覧</h1>

  <% if @drink_records.empty? %>
    <div class="bg-white p-6 rounded-lg shadow text-center text-gray-500">
      まだ記録がありません。<br>右上のボタンから新しいお酒を記録しましょう！
    </div>
  <% else %>
    <div class="grid grid-cols-1 gap-4">
      <% @drink_records.each do |record| %>
        <%= link_to record, class: "block bg-white rounded-lg shadow overflow-hidden hover:shadow-md transition active:scale-[0.98]" do %>
          <div class="flex items-center p-3">
            <% if record.image.attached? %>
              <%= image_tag record.image.variant(resize_to_limit: [100, 100]), class: "w-20 h-20 object-cover rounded-md flex-shrink-0" %>
            <% else %>
              <div class="w-20 h-20 bg-gray-200 rounded-md flex items-center justify-center flex-shrink-0">
                <span class="text-gray-400 text-xs">No Image</span>
              </div>
            <% end %>
            <div class="ml-4 flex-1 min-w-0">
              <h2 class="text-lg font-semibold text-gray-900 truncate"><%= record.title %></h2>
              <p class="text-sm text-gray-500 truncate mt-1"><%= record.comment %></p>
              <div class="mt-2 text-xs text-gray-400">
                <%= record.created_at.strftime("%Y/%m/%d %H:%M") %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
